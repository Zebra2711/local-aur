declare -g _patches=(
  # Staging
  [6446]="xwayland: support HiDPI scale"
  #[7919]="Implement new Input Capture protocol"
  [11572]="screencopy: implement transparency for non-shareable windows"
  [11704]="dwindle: add smart_split_on_drop option"


  [11216]="texture: avoid issuing many glTexSubImage2D calls"
  #[11303]="renderer: create fence after each surface pass"
  #[99999]="Experimental FP16"

  #[12057]="compositor: Block parent window interaction when modal dialog children window is open"

  # Unstable
  # [12090]="fix: onWrite spinning forever"

  # Merged
  [12446]="renderer: stop looping over null texture surfaces"
  [12418]="animation: improvement animation on multi refresh rate monitors"
  [12461]="buffers: revert buffer state merging"
  [12448]="fifo: unlock locksurfaces aswell"
  [12772]="input: guard null view() when processing mouse down"
  # [12263]="renderer/ime: fix fcitx5 popup artifacts"
  # [12289]="layout: include reserved area in float fit"
  # [12100]="config/keybinds: add a submap universal keybind flag"
)

if [[ ${#_patches[@]} -gt 0 ]]; then
    if [[ ! -d "patches" ]]; then
      mkdir -p "patches"
    fi
    for mr in "${!_patches[@]}"; do
        desc=$(echo "${_patches[$mr]}" | tr " " "-" | tr -d ":." | tr "/" "_")
        filepath="patches/${mr}-${desc}.patch"
        source+=("$filepath::${_url_patches}/${mr}.diff")
        local checksum="$(sha256sum "$filepath" | awk '{print $1}')"
        sha256sums+=($checksum)
    done
fi

prepare() {
  read -s
  cd "$_pkgsrc"
  git submodule init
  git config submodule.subprojects/udis86.url "$srcdir/udis86"
  git config submodule.subprojects/tracy.update none
  git -c protocol.file.allow=always submodule update --init --recursive --remote subprojects/hyprland-protocols subprojects/udis86

  if [[ -z "$(git config --get user.name)" ]]; then
    git config user.name local && git config user.email '<>' && git config commit.gpgsign false
  fi

  # [[ ! -d "patches" ]] && cp -r "${startdir}/patches" "${srcdir}/"

  #sed -i 's/find_package(glaze 6/find_package(glaze 7/' "hyprpm/CMakeLists.txt"

  local skip=('subprojects/*' 'flake.lock' '.github/*' 'nix/*')
  # local filter=(-p1 "${_skip[@]/#/-x }")
  local filter="-p1"
  for diff in "${skip[@]}"; do
    filter+=" -x '$diff'"
  done
  for mr in "${!_patches[@]}"; do
    msg2 "${mr}: ${_patches[${mr}]}"
    desc=$(echo "${_patches[$mr]}" | tr " " "-" | tr -d ":." | tr "/" "_")
    local file="$srcdir/patches/${mr}-${desc}.patch"
    local patch_cmd="filterdiff ${filter} \"$file\" | patch --no-backup-if-mismatch -Np1"

    # Test if patch applies cleanly with --dry-run
    if ! eval "$patch_cmd --dry-run" &>/dev/null; then
      error "Patch ${mr} will fail to apply"
      [[ -n "$(git status --porcelain)" ]] && git add . && git commit -m "Applied patches before ${mr} failure"
      eval "$patch_cmd" || true
      find . -name "*.rej" -exec catdiff {} \;
      return 1
    fi
    eval "$patch_cmd"
  done

  # hot fix patch
  patch -Np1 -i "$startdir/patches/0001-fix-crash-in-initial-group-sending.patch"
  patch -Np1 -i "$startdir/patches/0002-avoid-crash-on-inert-output.patch"
}

pkgver() {
  cd "$_pkgsrc"
  git describe --long --tags --abbrev=7 | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
  local cmake_options=(
    -B build
    -S "$_pkgsrc"
    -G Ninja
    -W no-dev
    -D CMAKE_BUILD_TYPE=None
    -D CMAKE_INSTALL_PREFIX=/usr
    -D BUILD_HYPRTESTER=OFF
    -D BUILD_TESTING=OFF
  )
  cmake "${cmake_options[@]}"
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm0644 "$_pkgsrc/LICENSE" -t "$pkgdir/usr/share/licenses/${pkgname}/"
  install -Dm0644 "$_pkgsrc/subprojects/udis86/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE-udis86"
}
