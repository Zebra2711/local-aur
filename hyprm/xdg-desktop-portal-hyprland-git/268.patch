+
+    Debug::log(LOG, "[input-capture] init successful");
+}
+
+void complete(sdbus::MethodCall& call) {
+    auto reply = call.createReply();
+    reply << (uint32_t)0;
+    reply << std::unordered_map<std::string, sdbus::Variant>{};
+    reply.send();
+}
