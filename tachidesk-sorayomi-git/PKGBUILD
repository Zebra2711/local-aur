# Maintainer: Zebra2711 <zebra2711t at gmail dot com>
# Contributor: Mahor Foruzesh <mahor1221 at gmail dot com>

pkgname=tachidesk-sorayomi-git
_pkgname="${pkgname%-git}"
_PkgName="$(echo "$_pkgname" | sed -e "s/\b./\u\0/g")"
_binname="$(echo "$_pkgname" | tr - _)"
pkgver=0.6.4.r547.7e50b48
pkgrel=1
pkgdesc='A free and open source manga reader to read manga from a Suwayomi-Server instance'
arch=('x86_64')
url="https://github.com/Zebra2711/$_PkgName"
license=('MPL2')
depends=('zenity'
    'xdg-user-dirs'
    'gtk3'
    'at-spi2-core')
optdepends=('suwayomi-server-preview-bin')
makedepends=('fvm'
    'cmake'
    'clang'
    'ninja'
    'pkg-config'
)
provides=("$_pkgname")
conflicts=("$_pkgname")
source=("git+$url.git")
sha256sums=('SKIP')

pkgver() {
  cd "$_PkgName"
  printf "%s.r%s.%s" "$(git describe --tags | cut -d"-" -f1)" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
    cd "${srcdir}/${_PkgName}"
    fvm use 3.29.2 --force
    fvm flutter config --enable-linux-desktop
    sed -i 's/intl: \^0\.20\.[0-9]*/intl: ^0.19.0/' "${srcdir}/${_PkgName}/pubspec.yaml"
}

build() {
    cd "${srcdir}/${_PkgName}"
    fvm flutter pub get --no-precompile
    fvm flutter gen-l10n
    fvm dart run build_runner build --delete-conflicting-outputs
    fvm flutter build linux --release \
        --dart-define=flutter.inspector.structuredErrors=false \
        --split-debug-info="${srcdir}/debug" \
        --no-tree-shake-icons \
        --dart-define=dart.vm.product=true
}

package() {
    cd ${pkgdir}
    mkdir -p usr/share/applications usr/share/icons usr/bin opt/$_PkgName
    install -Dm644 "${srcdir}/${_PkgName}/scripts/${_pkgname}.desktop" -t "usr/share/applications/"
    install -Dm644 "${srcdir}/${_PkgName}/assets/icons/launcher/sorayomi_icon.png" "${pkgdir}/usr/share/icons/${_pkgname}.png"
    cp -a "${srcdir}/${_PkgName}/build/linux/x64/release/bundle/" -T "opt/$_PkgName/"
    ln -sr "opt/$_PkgName/$_binname" "$pkgdir/usr/bin/${_pkgname}"
}
