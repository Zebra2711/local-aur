+
+namespace Screenshare {
+    enum eScreenshareType : uint8_t {
+        SHARE_MONITOR,
+        SHARE_WINDOW,
+        SHARE_REGION,
+        SHARE_NONE
+    };
+
+    enum eScreenshareError : uint8_t {
+        ERROR_NONE,
+        ERROR_UNKNOWN,
