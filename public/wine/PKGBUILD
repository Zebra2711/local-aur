_tkg_commit=57451d7428838707dad1112f2c6c6e29b82a26ed
_wine_commit=d62035da4aa91327c6e38a2c8a66b829eb0983ed
_staging_commit=f686957b39fb341e3586f33c3888160deb8d2478
_winehq_mr=https://gitlab.winehq.org/wine/wine/-/merge_requests
options=('staticlibs' '!lto' '!debug')
install="wine.install"
provides=("wine-staging=${pkgver}" "wine=${pkgver%%.r*}" 'wine-wow64')
conflicts=('wine' 'wine-wow64')
source=('30-win32-aliases.conf'
        'wine-binfmt.conf'
        'wine-hags.patch'
        'wine-wmclass.patch'
        'wine-isolate_home.patch'
)

declare -gA _mr_patches=(
    #[9124]="server: Inherit Wine process info for Unix side created process if exist"
    #[9104]="scrrun: Implement MoveFolder()"
		#[9165]="winex11: Call window_set_wm_state instead of map_window"
    [7797]="ntdll: Wait for all pending operations to be cancelled in NtCancelIoFileEx"
)

sha256sums=('9901a5ee619f24662b241672a7358364617227937d5f6d3126f70528ee5111e7'
            '6dfdefec305024ca11f35ad7536565f5551f09119dda2028f194aee8f77077a4'
            '23bd2a1254ec8a0a463bf0ee263377cc77187f56d8a3bd62d6c2b156e8222627'
            'f897dddbeeb27a020ca29eb32ddfa9a0022505aac000d7e5bb4a7053c793c665'
            '19c27563b3645479b21ef73379095191f193cdb14ce9818f149b55149c9a4623'
)

if [[ ${#_mr_patches[@]} -gt 0 ]]; then
    rm -rf "mr_patches" # clean old patches
    mkdir -p "mr_patches"

    for mr in "${!_mr_patches[@]}"; do
        desc=$(echo "${_mr_patches[$mr]}" | tr " " "-" | tr -d ":." | tr "/" "_")
        source+=("mr_patches/${mr}-${desc}.patch::${_winehq_mr}/${mr}.patch")
        sha256sums+=('SKIP')
    done
fi


# Add all patches from staging-patches folder if enabled
if [[ "$USE_STAGING_PATCHES" -eq 1 ]] && [[ -d "$srcdir/staging-patches" ]]; then
    for patch_file in "$srcdir/staging-patches"/*.{mypatch,patch}; do
        if [[ -f "$patch_file" ]]; then
            _patch_filename=$(basename "$patch_file")
            source+=("staging-patches/$_patch_filename")
            sha256sums+=('SKIP')
        fi
    done
fi

prepare() {
    # Allow ccache to work
    # mv wine $pkgname

		"${startdir}/tinysync.sh"
		cp -r "${startdir}"/{wine-staging,wine,wine-tkg-git} "${srcdir}/"

		# Get rid of old build dirs
    rm -rf build-{32,64}
    mkdir -p build-{32,64}

    ln -sf ../mr_patches mr_patches
    ln -sf ../staging-patches staging-patches

    # restore the wine tree to its git origin state, without wine-staging patches
    printf '%s\n' '  -> Cleaning wine source code tree...'
    git -C wine reset --hard HEAD  # restore tracked files
    git -C wine clean -xdf         # delete untracked files

    # change back to the wine ustream commit that this version of wine-staging is based in
    # printf '%s\n' '  -> Changing wine HEAD to the wine-staging base commit...'
    # git -C wine config --local advice.detachedHead false
    # git -C wine checkout "$(wine-staging/staging/patchinstall.py --upstream-commit)"

    # rm wine-staging/patches/Staging/000X-xxxxxx.patch

    # apply wine-staging patches
    printf '%s\n' '  -> Applying wine-staging patches...'
    wine-staging/staging/patchinstall.py DESTDIR="${srcdir}/wine" --all \
    --no-autoconf

    # Apply TKG patches
    _tkg_path="$srcdir"/wine-tkg-git/wine-tkg-git/wine-tkg-patches
    printf '%s\n' "  -> Applying TKG patches..."
    patch -Np1 -d wine -i "$_tkg_path"/proton/LAA/LAA-unix-staging.patch
    patch -Np1 -d wine -i "$_tkg_path"/proton/msvcrt_nativebuiltin/msvcrt_nativebuiltin_mainline.patch
    patch -Np1 -d wine -i "$_tkg_path"/proton/proton-win10-default/proton-win10-default.patch
    patch -Np1 -d wine -i "$_tkg_path"/hotfixes/GE/wine-hotfixes/pending/unity_crash_hotfix.patch
    # patch -Np1 -d wine -i "$_tkg_path"/misc/plasma_systray_fix/plasma_systray_fix.patch

    # Apply core patches
    printf '%s\n' "  -> Applying core patches..."
    patch -Np1 -d wine -i "$srcdir"/wine-wmclass.patch
    patch -Np1 -d wine -i "$srcdir"/wine-isolate_home.patch
    patch -Np1 -d wine -i "$srcdir"/wine-hags.patch

    # Apply MR patches
    # read -s
    printf '%s\n' "  -> Applying MR patches..."
    for mr in "${!_mr_patches[@]}"; do
        printf '%s\n' "======================================================="
        printf '%s\n' "  -> Applying MR ${mr} patch: ${_mr_patches[${mr}]}"
        desc=$(echo "${_mr_patches[$mr]}" | tr " " "-" | tr -d ":." | tr "/" "_")
        patch -Np1 -d wine -i "$srcdir/mr_patches/${mr}-${desc}.patch"
        printf '%s\n' "======================================================="
    done
    # read -s
    # Apply staging-patches
    if [[ "$USE_STAGING_PATCHES" -eq 1 ]] && [[ -d "$srcdir/staging-patches" ]]; then
        printf '%s\n' "  -> Applying additional staging patches..."
        for patch_file in "$srcdir/staging-patches"/*.{mypatch,patch}; do
            if [[ -f "$patch_file" ]]; then
                printf '%s\n' "  -> Applying $(basename "$patch_file")..."
                patch -Np1 -d wine -i "$patch_file"
            fi
        done
    fi

    # Run wine build generation tools
    cd wine
    # sed -i '/^EXTRAINCL/ a EXTRALIBS = -lm' dlls/d3d10/Makefile.in
    ./tools/make_requests
    ./tools/make_specfiles
    ./dlls/winevulkan/make_vulkan
    autoreconf -fiv
    rm -rf autom4te.cache
}

pkgver() {
    _pkgver=$(git -C wine describe --long --tags | sed 's/\([^-]*-g\)/r\1/;s/-/./g;s/^wine\.//;s/^v//;s/\.rc/rc/')
    if [[ "$NTSYNC" -eq "1" ]]; then
        echo "$_pkgver" | sed 's/g/ntsync.g/'
    else
        echo "$_pkgver"
    fi
}

build() {

    export __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/10_nvidia.json

    # Doesn't compile without remove these flags as of 4.10
    # incompatible-pointer-types: https://bugs.gentoo.org/919758
    # export CFLAGS="$CFLAGS -ffat-lto-objects -Wno-error=incompatible-pointer-types"

    # apply flags for cross-compilation
    export CROSSCFLAGS="-O2 -pipe -g"
    export CROSSCXXFLAGS="-O2 -pipe -g"
    export CROSSLDFLAGS="-Wl,-O1"

    local -a split=($CFLAGS)
    local -A flags
    for opt in "${split[@]}"; do flags["${opt%%=*}"]="${opt##*=}"; done
    local march="${flags["-march"]:-nocona}"
    local mtune="${flags["-mtune"]:-core-avx2}"

    # Architecture specific optimizations
    # Tiger Lake supports -march=tigerlake but we'll use -march=native for broad compatibility
    local march="tigerlake"  # Specific to 11th gen Intel
    local mtune="tigerlake"

    # From Proton
    OPTIMIZE_FLAGS="-O2 -march=$march -mtune=$mtune -mavx2 -mfpmath=sse -pipe"
    OPTIMIZE_FLAGS+=" -mprefer-avx128"
    PERF_FLAGS="-fomit-frame-pointer"
    SANITY_FLAGS="-fwrapv -fno-strict-aliasing"
    DEBUG_FLAGS="-ffunction-sections -fdata-sections -fno-omit-frame-pointer"
    WARNING_FLAGS="-Wno-incompatible-pointer-types"
    STRIP_FLAGS="-s"

    # LTO flags for better linking optimization with GCC 15
    #LTO_CFLAGS="-flto=auto -fuse-linker-plugin -fdevirtualize-at-ltrans"
    #LTO_LDFLAGS="-flto=auto -fuse-linker-plugin"

    # Disable assertions
    export CPPFLAGS="-U_FORTIFY_SOURCE -D_FORTIFY_SOURCE=0 -DNDEBUG -D_NDEBUG"

    # Combined flags
    COMMON_FLAGS="$OPTIMIZE_FLAGS $SANITY_FLAGS $DEBUG_FLAGS $WARNING_FLAGS $STRIP_FLAGS"
    COMMON_LDFLAGS="-Wl,-O1,--sort-common,--as-needed"

    export LDFLAGS="$COMMON_LDFLAGS $LTO_LDFLAGS"
    export CROSSLDFLAGS="$COMMON_LDFLAGS -Wl,--file-alignment,4096"

    # build wine-staging 64-bit
    # (according to the wine wiki, this 64-bit/32-bit building order is mandatory)
    printf '%s\n' '  -> Building wine-staging-64...'
    export CFLAGS="$COMMON_FLAGS -mcmodel=small $LTO_CFLAGS"
    export CXXFLAGS="$COMMON_FLAGS -mcmodel=small -std=c++17 $LTO_CFLAGS"
    export CROSSCFLAGS="$COMMON_FLAGS -mcmodel=small"
    export CROSSCXXFLAGS="$COMMON_FLAGS -mcmodel=small -std=c++17"
    export PKG_CONFIG_PATH="/usr/lib/pkgconfig:/usr/share/pkgconfig"
    cd "${srcdir}/build-64"
    ../wine/configure \
        --prefix='/usr' \
        --libdir='/usr/lib' \
        --with-x \
        --with-wayland \
        --with-gstreamer \
        --with-freetype \
        --with-mingw \
        --with-alsa \
        --with-xattr \
        --without-oss \
        --disable-winemenubuilder \
        --enable-win64 \
        --disable-tests
    make -j$(nproc)

    # build wine-staging 32-bit
    printf '%s\n' '  -> Building wine-staging-32...'
    export CFLAGS="$COMMON_FLAGS -mstackrealign $LTO_CFLAGS"
    export CXXFLAGS="$COMMON_FLAGS -mstackrealign -std=c++17 $LTO_CFLAGS"
    export CROSSCFLAGS="$COMMON_FLAGS -mstackrealign"
    export CROSSCXXFLAGS="$COMMON_FLAGS -mstackrealign -std=c++17"
    export PKG_CONFIG_PATH="/usr/lib32/pkgconfig:/usr/share/pkgconfig"
    cd "${srcdir}/build-32"
    export PKG_CONFIG_PATH='/usr/lib32/pkgconfig'
    ../wine/configure \
        --prefix='/usr' \
        --libdir='/usr/lib' \
        --with-x \
        --with-wayland \
        --with-gstreamer \
        --with-freetype \
        --with-mingw \
        --with-alsa \
        --with-xattr \
        --without-oss \
        --disable-winemenubuilder \
        --with-wine64="${srcdir}/build-64" \
        --disable-tests
    make -j$(nproc)
}

package() {
    # package wine-staging 32-bit
    #(according to the wine wiki, this reverse 32-bit/64-bit packaging order is important)
    printf '%s\n' '  -> Packaging wine-staging-32...'
    cd "${srcdir}/build-32"
    make prefix="${pkgdir}/usr" \
         libdir="${pkgdir}/usr/lib" \
         dlldir="${pkgdir}/usr/lib/wine" \
         install

    # package wine-staging 64-bit
    printf '%s\n' '  -> Packaging wine-staging-64...'
    cd "${srcdir}/build-64"
    make prefix="${pkgdir}/usr" \
         libdir="${pkgdir}/usr/lib" \
         dlldir="${pkgdir}/usr/lib/wine" \
         install

    # font aliasing settings for win32 applications
    install -d -m755 "${pkgdir}/usr/share/fontconfig/conf.default"
    install -D -m644 "${srcdir}/30-win32-aliases.conf" -t "${pkgdir}/usr/share/fontconfig/conf.avail"
    ln -s ../conf.avail/30-win32-aliases.conf "${pkgdir}/usr/share/fontconfig/conf.default/30-win32-aliases.conf"

    # wine binfmt
    install -D -m644 "${srcdir}/wine-binfmt.conf" "${pkgdir}/usr/lib/binfmt.d/wine.conf"

    # strip native PE libraries
    i686-w64-mingw32-strip --strip-unneeded "${pkgdir}/usr/lib/wine/i386-windows"/*.dll
    x86_64-w64-mingw32-strip --strip-unneeded "${pkgdir}/usr/lib/wine/x86_64-windows"/*.dll

    # Clean up build artifacts
    # find "$pkgdir/usr/lib/wine" -regextype egrep -regex '.*\.(a|def)' -delete

}

